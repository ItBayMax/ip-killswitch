{
  "compilerOptions": {
    "composite": true,
    "skipLibCheck": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "noEmit": false,
    "outDir": "./.tsbuild",
    "types": ["node"]
  },
  "include": ["vite.config.ts", "scripts/**/*.mjs"]
}
